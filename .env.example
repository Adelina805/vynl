# Copy to .env and .env.local (Next.js loads both; Prisma CLI uses .env via prisma.config.ts)
DATABASE_URL="file:./data/gallery/dev.db"

# Optional: override image + DB parent directory (default: ./data/gallery)
# GALLERY_DATA_ROOT=

# Optional: Bearer token for DELETE /api/gallery/[id]
# GALLERY_ADMIN_SECRET=
